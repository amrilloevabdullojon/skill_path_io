# ──────────────────────────────────────────────────────────────────────────────
# SkillPath Academy — environment variables reference
#
# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# For production (Docker / PaaS):
#   Inject these via your secrets manager — never commit .env.local to git.
#
# Run `npm run check:env` to validate your configuration before starting.
# Run `npm run check:env:prod` for additional production-mode strength checks.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Pooled connection string (PgBouncer / Supabase pooler) for the app.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct (non-pooled) connection for Prisma migrations.
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Public URL the app is served from (used in OAuth redirects and emails).
NEXTAUTH_URL="https://your-domain.com"
# Strong random secret — generate with: openssl rand -base64 32
# MUST be ≥ 32 characters in production.
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ── Supabase (optional — used for Storage, Realtime, Row-Level Security) ─────
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"

# ── AI — Gemini (primary provider) ───────────────────────────────────────────
# Required for AI mentor, quiz review, interview, and other AI features.
# Obtain at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"

# ── AI — Anthropic (optional secondary provider) ─────────────────────────────
# ANTHROPIC_API_KEY="your-anthropic-api-key"
# ANTHROPIC_MODEL="claude-3-5-sonnet-latest"
# ANTHROPIC_MAX_TOKENS="700"

# ── Rate limits ───────────────────────────────────────────────────────────────
MENTOR_RATE_LIMIT_MAX_REQUESTS="20"
MENTOR_RATE_LIMIT_WINDOW_MS="60000"
ADMIN_AI_RATE_LIMIT_MAX_REQUESTS="30"
ADMIN_AI_RATE_LIMIT_WINDOW_MS="60000"

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set BOTH to "true" only in local development / demo deployments.
# DEFAULT: false — demo mode is DISABLED unless explicitly enabled.
# In production, leave these unset or set to "false".
ENABLE_DEMO_MODE="false"
NEXT_PUBLIC_ENABLE_DEMO_MODE="false"

# When demo mode is ON, these credentials are required:
# DEMO_USER_EMAIL="demo@example.com"
# DEMO_USER_PASSWORD="demo-password-here"

# ── SaaS ──────────────────────────────────────────────────────────────────────
DEFAULT_SUBSCRIPTION_PLAN="FREE"
